{
  "title": "DualContext — Investigation Analytics",
  "description": "Productivity and groundedness analytics over DualContext investigations. Driven live by HEC events (sourcetype=dualcontext_investigation) emitted by dualcontext/telemetry.py — no hardcoded figures. Import via Dashboards → Create New → Dashboard Studio → Source.",
  "schemaVersion": "1.1",
  "visualizations": {
    "viz_total": {
      "type": "splunk.singlevalue",
      "title": "Total Investigations",
      "dataSources": { "primary": "ds_total" },
      "options": { "numberPrecision": 0, "majorColor": "#0A84FF" }
    },
    "viz_pass_rate": {
      "type": "splunk.singlevalue",
      "title": "Groundedness Pass Rate (≥ 0.70)",
      "dataSources": { "primary": "ds_pass_rate" },
      "options": {
        "unit": "%", "unitPosition": "after", "numberPrecision": 0,
        "majorColor": "> majorValue | rangeValue(passRange)"
      },
      "context": {
        "passRange": [
          { "to": 60, "value": "#D41F1F" },
          { "from": 60, "to": 85, "value": "#F1813F" },
          { "from": 85, "value": "#118832" }
        ]
      }
    },
    "viz_avg_ground": {
      "type": "splunk.singlevalue",
      "title": "Avg Groundedness",
      "dataSources": { "primary": "ds_avg_ground" },
      "options": {
        "numberPrecision": 2,
        "majorColor": "> majorValue | rangeValue(groundRange)",
        "sparklineDisplay": "below"
      },
      "context": {
        "groundRange": [
          { "to": 0.30, "value": "#D41F1F" },
          { "from": 0.30, "to": 0.70, "value": "#F1813F" },
          { "from": 0.70, "value": "#118832" }
        ]
      }
    },
    "viz_avg_time": {
      "type": "splunk.singlevalue",
      "title": "Avg Investigation Time",
      "dataSources": { "primary": "ds_avg_time" },
      "options": { "unit": "s", "unitPosition": "after", "numberPrecision": 1, "majorColor": "#1D9E75" }
    },
    "viz_ground_trend": {
      "type": "splunk.line",
      "title": "Groundedness Over Time — answers stay grounded as the codebase evolves",
      "dataSources": { "primary": "ds_ground_trend" },
      "options": { "yAxisMin": 0, "yAxisMax": 1, "yAxisTitleText": "groundedness", "legendDisplay": "off" }
    },
    "viz_token_reduction": {
      "type": "splunk.singlevalue",
      "title": "Avg SigMap Token Reduction",
      "dataSources": { "primary": "ds_token_reduction" },
      "options": { "unit": "%", "unitPosition": "after", "numberPrecision": 1, "majorColor": "#1D9E75" }
    },
    "viz_recent": {
      "type": "splunk.table",
      "title": "Recent Investigations",
      "dataSources": { "primary": "ds_recent" },
      "options": {
        "tableFormat": {
          "rowBackgroundColors": "> table | seriesByName('result') | matchValue(resultColors)"
        }
      },
      "context": {
        "resultColors": [
          { "match": "PASS", "value": "#0E1A0E" },
          { "match": "FAIL", "value": "#2A0E0E" }
        ]
      }
    }
  },
  "dataSources": {
    "ds_total": {
      "type": "ds.search",
      "options": {
        "query": "index=main sourcetype=dualcontext_investigation | stats count as investigations | fields investigations",
        "queryParameters": { "earliest": "-30d@d", "latest": "now" }
      },
      "name": "Total investigations"
    },
    "ds_pass_rate": {
      "type": "ds.search",
      "options": {
        "query": "index=main sourcetype=dualcontext_investigation | stats count as total, count(eval(groundedness>=0.7)) as passed | eval rate=round(passed/total*100,0) | fields rate",
        "queryParameters": { "earliest": "-30d@d", "latest": "now" }
      },
      "name": "Pass rate"
    },
    "ds_avg_ground": {
      "type": "ds.search",
      "options": {
        "query": "index=main sourcetype=dualcontext_investigation | stats avg(groundedness) as g | eval g=round(g,2) | fields g",
        "queryParameters": { "earliest": "-30d@d", "latest": "now" }
      },
      "name": "Avg groundedness"
    },
    "ds_avg_time": {
      "type": "ds.search",
      "options": {
        "query": "index=main sourcetype=dualcontext_investigation | stats avg(investigation_ms) as ms | eval seconds=round(ms/1000,1) | fields seconds",
        "queryParameters": { "earliest": "-30d@d", "latest": "now" }
      },
      "name": "Avg time"
    },
    "ds_ground_trend": {
      "type": "ds.search",
      "options": {
        "query": "index=main sourcetype=dualcontext_investigation | timechart span=1h avg(groundedness) as groundedness",
        "queryParameters": { "earliest": "-7d@d", "latest": "now" }
      },
      "name": "Groundedness trend"
    },
    "ds_token_reduction": {
      "type": "ds.search",
      "options": {
        "query": "index=main sourcetype=dualcontext_investigation | stats avg(token_reduction_pct) as r | eval r=round(r,1) | fields r",
        "queryParameters": { "earliest": "-30d@d", "latest": "now" }
      },
      "name": "Token reduction"
    },
    "ds_recent": {
      "type": "ds.search",
      "options": {
        "query": "index=main sourcetype=dualcontext_investigation | eval result=if(groundedness>=0.7,\"PASS\",\"FAIL\"), seconds=round(investigation_ms/1000,1) | sort -_time | table _time query groundedness result seconds token_reduction_pct | head 25",
        "queryParameters": { "earliest": "-30d@d", "latest": "now" }
      },
      "name": "Recent investigations"
    }
  },
  "inputs": {
    "input_timerange": {
      "type": "input.timerange",
      "title": "Time range",
      "options": { "token": "global_time", "defaultValue": "-30d@d,now" }
    }
  },
  "layout": {
    "type": "absolute",
    "globalInputs": ["input_timerange"],
    "options": { "width": 1440, "height": 1040 },
    "structure": [
      { "item": "viz_total", "type": "block", "position": { "x": 0, "y": 0, "w": 360, "h": 200 } },
      { "item": "viz_pass_rate", "type": "block", "position": { "x": 360, "y": 0, "w": 360, "h": 200 } },
      { "item": "viz_avg_ground", "type": "block", "position": { "x": 720, "y": 0, "w": 360, "h": 200 } },
      { "item": "viz_avg_time", "type": "block", "position": { "x": 1080, "y": 0, "w": 360, "h": 200 } },
      { "item": "viz_ground_trend", "type": "block", "position": { "x": 0, "y": 200, "w": 1080, "h": 400 } },
      { "item": "viz_token_reduction", "type": "block", "position": { "x": 1080, "y": 200, "w": 360, "h": 400 } },
      { "item": "viz_recent", "type": "block", "position": { "x": 0, "y": 600, "w": 1440, "h": 420 } }
    ]
  }
}
